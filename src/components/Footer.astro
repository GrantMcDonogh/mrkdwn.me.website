---
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: "Features", href: "#features" },
  { label: "Screenshots", href: "#screenshots" },
  { label: "Roadmap", href: "#roadmap" },
  { label: "Pricing", href: "#pricing" },
];

const legalLinks = [
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms of Service", href: "/terms" },
];
---

<footer class="border-t border-edge py-12" style="background-color: var(--bg-secondary);">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-col md:flex-row justify-between gap-8">
      <!-- Brand -->
      <div class="flex flex-col gap-3">
        <a href="/" class="text-body font-bold text-xl">
          mrkdwn<span class="text-accent">.</span>me
        </a>
        <p class="text-muted text-sm max-w-xs">
          Cloud-based knowledge management inspired by Obsidian. Your notes, everywhere.
        </p>
      </div>

      <!-- Links -->
      <div class="flex gap-12 sm:gap-16">
        <div>
          <div class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">Product</div>
          <nav class="flex flex-col gap-2">
            {navLinks.map((link) => (
              <a href={link.href} class="text-sm text-muted hover:text-body transition-colors">
                {link.label}
              </a>
            ))}
            <a href="https://app.mrkdwn.me" class="text-sm text-muted hover:text-body transition-colors">
              Launch App
            </a>
          </nav>
        </div>

        <div>
          <div class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">Legal</div>
          <nav class="flex flex-col gap-2">
            {legalLinks.map((link) => (
              <a href={link.href} class="text-sm text-muted hover:text-body transition-colors">
                {link.label}
              </a>
            ))}
          </nav>
        </div>

      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-edge flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-muted">
        &copy; {currentYear} mrkdwn.me. All rights reserved.
      </p>
    </div>
  </div>
</footer>
