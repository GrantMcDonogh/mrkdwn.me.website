---
import Section from "./Section.astro";
import Button from "./Button.astro";

const features = [
  "Unlimited vaults & notes",
  "Markdown editor with live preview",
  "Wiki links, backlinks & graph",
  "AI Chat & edit mode (Claude)",
  "Vault sharing & collaboration",
  "Version history & audit log",
  "Trash with 5-year retention",
  "REST API & MCP Server",
  "Import from Obsidian / export as ZIP & PDF",
  "Real-time sync across devices",
];
---

<Section id="pricing">
  <div class="max-w-2xl mx-auto">
    <!-- Limited-time offer card -->
    <div class="rounded-xl border border-accent shadow-xl shadow-accent/10 p-8 text-center reveal" style="background-color: var(--bg-secondary);">
      <div class="flex items-center justify-center gap-2 mb-4">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7f6df2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span class="text-accent text-sm font-bold uppercase tracking-wider">Limited-Time Offer</span>
      </div>

      <h2 class="text-3xl md:text-4xl font-extrabold text-body">
        Free until <span class="text-accent">May 4th, 2026</span>
      </h2>
      <p class="text-muted text-lg mt-3 max-w-md mx-auto">
        Sign up now and get full access to everything. No credit card required. This offer will be removed soon.
      </p>

      <ul class="mt-8 space-y-3 text-left max-w-sm mx-auto">
        {features.map((feature) => (
          <li class="flex items-center gap-3 text-sm text-body">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#7f6df2"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
            {feature}
          </li>
        ))}
      </ul>

      <div class="mt-8">
        <Button
          href="https://app.mrkdwn.me"
          variant="primary"
          size="lg"
          class="w-full sm:w-auto text-center"
        >
          Get Started Free
        </Button>
      </div>
    </div>
  </div>
</Section>
