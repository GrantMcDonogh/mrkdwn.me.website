    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="text-3xl md:text-4xl font-extrabold text-body mb-2">Terms of Service</h1>
      <p class="text-sm text-muted mb-12">Last updated: March 5, 2026</p>

